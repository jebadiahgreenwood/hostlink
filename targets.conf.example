# ~/.config/hostlink/targets.conf
# Example targets configuration for hostlink-cli
# Set permissions to 0600: chmod 600 ~/.config/hostlink/targets.conf

[desktop]
transport = unix
socket = /run/hostlink/hostlink.sock
token = REPLACE_WITH_TOKEN

[dgx-spark]
transport = tcp
address = 10.0.0.2
port = 9876
token = REPLACE_WITH_TOKEN

[dgx-spark-02]
transport = tcp
address = 10.0.0.3
port = 9876
token = REPLACE_WITH_DIFFERENT_TOKEN
